# Neo4j connection. Defaults match a local `neo4j console` install.
# Copy this file to .env and fill in NEO4J_PASSWORD with the one you set
# the first time you logged into http://localhost:7474.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Future: real embedder for Phase 6
DASHSCOPE_API_KEY=sk-your-key-here
